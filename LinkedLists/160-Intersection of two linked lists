/**
 * Definition for singly-linked list.
 * public class ListNode {
 *     int val;
 *     ListNode next;
 *     ListNode(int x) {
 *         val = x;
 *         next = null;
 *     }
 * }
 */
public class Solution {
    public ListNode getIntersectionNode(ListNode headA, ListNode headB) {
        if(headA==headB){
            return headA;
        }
        ListNode node1=headA;
        ListNode node2=headB;
        while(node1!=null){
            node2=headB;
            while(node2!=null){
                if(node1.next==node2.next){
                    return node1.next;
                }
                if(node1.next==node2){
                    return node2;
                }
                if(node2.next==node1){
                    return node1;
                }
                node2=node2.next;
            }
        node1=node1.next;
        }
    return null;
    }
}
